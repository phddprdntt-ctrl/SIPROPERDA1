<script>
(function(){
  var pages = document.querySelectorAll('.page');
  var navLinks = document.querySelectorAll('.nav-link[data-page]');
  var mainNav = document.getElementById('mainNav');
  var menuToggle = document.getElementById('menuToggle');
  var menuIcon = document.getElementById('menuIcon');
  var navMore = document.getElementById('navMore');
  var moreBtn = document.getElementById('moreBtn');

  function goToPage(pageId){
    pages.forEach(function(p){ p.classList.toggle('active', p.id === 'page-' + pageId); });
    navLinks.forEach(function(l){
      if(l.classList.contains('back-link')) return;
      l.classList.toggle('active', l.dataset.page === pageId);
    });
    window.scrollTo({ top:0, behavior:'smooth' });
    if(mainNav.classList.contains('open')){ mainNav.classList.remove('open'); }
  }

  navLinks.forEach(function(link){
    link.addEventListener('click', function(e){
      e.preventDefault();
      goToPage(this.dataset.page);
    });
  });

  menuToggle.addEventListener('click', function(){
    mainNav.classList.toggle('open');
    menuIcon.setAttribute('href', mainNav.classList.contains('open') ? '#i-close' : '#i-menu');
  });

  moreBtn.addEventListener('click', function(e){
    e.preventDefault();
    navMore.classList.toggle('open');
  });
  document.addEventListener('click', function(e){
    if(!navMore.contains(e.target)){ navMore.classList.remove('open'); }
  });

  /* Year tabs */
  document.querySelectorAll('.year-tabs').forEach(function(tabGroup){
    var group = tabGroup.dataset.group;
    tabGroup.querySelectorAll('button').forEach(function(btn){
      btn.addEventListener('click', function(){
        tabGroup.querySelectorAll('button').forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        var year = this.dataset.year;
        document.querySelectorAll('.year-panel[data-group="' + group + '"]').forEach(function(panel){
          panel.classList.toggle('active', panel.dataset.year === year);
        });
      });
    });
