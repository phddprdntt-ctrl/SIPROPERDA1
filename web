<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIPROPERDA</title>
<title> Sistem Informasi Progres Pembentukan Peraturan Daerah</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
  :root{
    --c-primary:#304C64;
    --c-primary-dark:#22394B;
    --c-primary-darker:#182A38;
    --c-primary-light:#4A6B87;
    --c-primary-tint:#E8EDF1;
    --c-accent:#C89A4B;
    --c-accent-dark:#A87F38;
    --c-accent-tint:#F6ECD9;
    --c-bg:#F5F7F9;
    --c-surface:#FFFFFF;
    --c-text:#1C2B36;
    --c-text-muted:#5C7488;
    --c-border:#DEE5EA;
    --c-success:#2F7D5C;
    --c-success-tint:#E4F2EC;
    --c-warning:#B7791B;
    --c-warning-tint:#FBF0DD;
    --c-info:#3A5A75;
    --c-info-tint:#E6ECF1;

    --font-display:'Fraunces', serif;
    --font-body:'Plus Jakarta Sans', sans-serif;

    --radius-sm:8px;
    --radius-md:14px;
    --radius-lg:22px;
    --shadow-sm: 0 1px 2px rgba(24,42,56,0.06), 0 1px 1px rgba(24,42,56,0.04);
    --shadow-md: 0 8px 24px rgba(24,42,56,0.10);
    --shadow-lg: 0 20px 48px rgba(24,42,56,0.16);
    --header-h: 78px;
  }

  *,*::before,*::after{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    margin:0;
    font-family:var(--font-body);
    color:var(--c-text);
    background:var(--c-bg);
    -webkit-font-smoothing:antialiased;
    line-height:1.55;
  }
  img,svg{ display:block; max-width:100%; }
  a{ color:inherit; text-decoration:none; }
  button{ font-family:inherit; cursor:pointer; }
  ul{ margin:0; padding:0; list-style:none; }
  h1,h2,h3,h4{ font-family:var(--font-display); margin:0; font-weight:600; }
  p{ margin:0; }

  :focus-visible{ outline:2.5px solid var(--c-accent); outline-offset:3px; border-radius:4px; }

  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-size:12.5px; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
    color:var(--c-accent-dark);
  }
  .eyebrow::before{ content:""; width:18px; height:2px; background:var(--c-accent); display:inline-block; }

  .wrap{ max-width:1180px; margin:0 auto; padding:0 28px; }

  /* ============ HEADER ============ */
  .site-header{
    position:sticky; top:0; z-index:100;
    background:var(--c-primary);
    color:#fff;
    height:var(--header-h);
    display:flex; align-items:center;
    box-shadow:0 2px 12px rgba(8,18,26,0.18);
  }
  .site-header .wrap{ display:flex; align-items:center; justify-content:space-between; width:100%; gap:24px; }
  .brand{ display:flex; align-items:center; gap:12px; }
  .brand-mark{ width:42px; height:42px; flex-shrink:0; }
  .brand-text{ display:flex; flex-direction:column; line-height:1.15; }
  .brand-text .brand-name{ font-family:var(--font-display); font-weight:700; font-size:20px; letter-spacing:.02em; }
  .brand-text .brand-sub{ font-size:10.5px; color:#C7D3DC; letter-spacing:.03em; max-width:230px; }

  .main-nav{ display:flex; align-items:center; gap:6px; }
  .main-nav a, .main-nav button.nav-link{
    background:none; border:none; color:#DCE6ED; font-family:inherit;
    font-size:13.5px; font-weight:600; letter-spacing:.03em;
    padding:10px 16px; border-radius:999px; position:relative;
    transition:background .18s ease, color .18s ease;
  }
  .main-nav a:hover, .main-nav button.nav-link:hover{ background:rgba(255,255,255,0.10); color:#fff; }
  .main-nav a.active, .main-nav button.nav-link.active{ background:var(--c-accent); color:var(--c-primary-darker); }

  .nav-more{ position:relative; }
  .more-panel{
    position:absolute; top:calc(100% + 10px); right:0;
    background:#fff; color:var(--c-text); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); padding:14px 16px; width:200px;
    opacity:0; visibility:hidden; transform:translateY(-6px);
    transition:opacity .16s ease, transform .16s ease, visibility .16s;
    font-size:13px;
  }
  .nav-more.open .more-panel{ opacity:1; visibility:visible; transform:translateY(0); }
  .more-panel strong{ display:block; font-family:var(--font-display); font-size:14px; margin-bottom:4px;}
  .more-panel span{ color:var(--c-text-muted); }

  .menu-toggle{ display:none; background:none; border:none; color:#fff; width:40px; height:40px; }

  /* ============ PAGES ============ */
  .page{ display:none; animation:fadeIn .35s ease; }
  .page.active{ display:block; }
  @keyframes fadeIn{ from{ opacity:0; transform:translateY(6px);} to{ opacity:1; transform:translateY(0);} }

  .back-link{
    display:inline-flex; align-items:center; gap:6px;
    font-size:13px; font-weight:600; color:var(--c-primary-light);
    margin:26px 0 0;
  }
  .back-link:hover{ color:var(--c-primary); }
  .back-link svg{ width:15px; height:15px; }

  .subpage-header{ padding:18px 0 34px; border-bottom:1px solid var(--c-border); margin-bottom:36px; }
  .subpage-header h1{ font-size:clamp(28px,4vw,38px); margin-top:10px; }
  .subpage-header p{ color:var(--c-text-muted); font-size:15.5px; margin-top:8px; max-width:640px; }

  /* ============ HERO ============ */
  .hero{ padding:64px 0 56px; }
  .hero .wrap{ display:grid; grid-template-columns:1.1fr .9fr; gap:56px; align-items:center; }
  .hero h1{
    font-size:clamp(30px,4vw,44px); line-height:1.14; margin:14px 0 20px;
    letter-spacing:-.01em;
  }
  .hero h1 em{ font-style:normal; color:var(--c-primary); border-bottom:4px solid var(--c-accent); }
  .hero p.lead{ font-size:16px; color:var(--c-text-muted); max-width:560px; }
  .hero .cta-row{ display:flex; gap:12px; margin-top:30px; flex-wrap:wrap; }

  .btn{
    display:inline-flex; align-items:center; gap:8px;
    padding:12px 22px; border-radius:999px; font-size:14px; font-weight:700;
    border:1.5px solid transparent; transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
  }
  .btn svg{ width:16px; height:16px; }
  .btn-primary{ background:var(--c-primary); color:#fff; }
  .btn-primary:hover{ background:var(--c-primary-dark); box-shadow:var(--shadow-md); transform:translateY(-1px); }
  .btn-accent{ background:var(--c-accent); color:var(--c-primary-darker); }
  .btn-accent:hover{ background:var(--c-accent-dark); box-shadow:var(--shadow-md); transform:translateY(-1px); }
  .btn-ghost{ background:transparent; border-color:var(--c-border); color:var(--c-text); }
  .btn-ghost:hover{ border-color:var(--c-primary-light); color:var(--c-primary); }
  .btn-block{ width:100%; justify-content:center; }
  .btn[disabled]{ opacity:.55; cursor:not-allowed; }

  /* hero preview card */
  .preview-card{
    background:var(--c-surface); border-radius:var(--radius-lg);
    box-shadow:var(--shadow-lg); overflow:hidden; border:1px solid var(--c-border);
  }
  .preview-card__top{ background:var(--c-primary); padding:16px 22px; display:flex; align-items:center; justify-content:space-between; }
  .preview-card__top span{ color:#CBD8E1; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; }
  .preview-card__top strong{ color:#fff; font-family:var(--font-display); font-size:15px; display:block; margin-top:2px; }
  .preview-card__dot{ width:9px; height:9px; border-radius:50%; background:var(--c-accent); box-shadow:0 0 0 4px rgba(200,154,75,.25); }
  .preview-card__body{ padding:22px; }
  .preview-card__body .ranperda-name{ font-size:13.5px; font-weight:700; margin-bottom:16px; color:var(--c-text); }

  .stage-tracker-v{ display:flex; flex-direction:column; }
  .stage-tracker-v .stage{ display:flex; gap:14px; position:relative; padding-bottom:22px; }
  .stage-tracker-v .stage:last-child{ padding-bottom:0; }
  .stage-tracker-v .stage::before{
    content:""; position:absolute; left:11px; top:24px; bottom:0; width:2px; background:var(--c-border);
  }
  .stage-tracker-v .stage:last-child::before{ display:none; }
  .stage-tracker-v .stage.done::before{ background:var(--c-accent); }
  .stage-node{ width:24px; height:24px; border-radius:50%; border:2.5px solid var(--c-border); background:#fff; flex-shrink:0; display:flex; align-items:center; justify-content:center; z-index:1; }
  .stage.done .stage-node{ background:var(--c-accent); border-color:var(--c-accent); }
  .stage.current .stage-node{ border-color:var(--c-primary); }
  .stage.current .stage-node::after{ content:""; width:9px; height:9px; border-radius:50%; background:var(--c-primary); }
  .stage.done .stage-node svg{ width:13px; height:13px; color:#fff; }
  .stage-label{ padding-top:2px; }
  .stage-label strong{ display:block; font-size:13px; }
  .stage-label span{ font-size:11.5px; color:var(--c-text-muted); }
  .stage.current .stage-label strong{ color:var(--c-primary); }
  .stage.upcoming .stage-label strong{ color:var(--c-text-muted); font-weight:600; }

  /* ============ SIGNATURE FLOW (hero background motif) ============ */
  .hero{ position:relative; overflow:hidden; }
  .hero-bg-motif{ position:absolute; inset:0; z-index:0; opacity:.55; pointer-events:none; }
  .hero .wrap{ position:relative; z-index:1; }

  /* ============ SECTION CARDS (landing) ============ */
  .section-cards{ padding:12px 0 72px; }
  .section-cards .kicker{ text-align:center; margin-bottom:34px; }
  .section-cards .kicker h2{ font-size:clamp(22px,3vw,28px); margin-top:10px; }
  .card-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:22px; }
  .info-card{
    background:var(--c-surface); border:1px solid var(--c-border); border-radius:var(--radius-md);
    padding:28px 26px; box-shadow:var(--shadow-sm);
    transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    display:flex; flex-direction:column; gap:14px; text-align:left;
    border-top:3px solid transparent;
  }
  .info-card:hover{ transform:translateY(-4px); box-shadow:var(--shadow-md); border-top-color:var(--c-accent); }
  .info-card .icon-badge{
    width:48px; height:48px; border-radius:12px; background:var(--c-primary-tint);
    display:flex; align-items:center; justify-content:center; color:var(--c-primary);
  }
  .info-card .icon-badge svg{ width:24px; height:24px; }
  .info-card h3{ font-size:18px; }
  .info-card p{ color:var(--c-text-muted); font-size:14px; flex-grow:1; }
  .info-card .card-link{ font-size:13.5px; font-weight:700; color:var(--c-primary); display:inline-flex; align-items:center; gap:6px; }
  .info-card .card-link svg{ width:14px; height:14px; transition:transform .15s ease; }
  .info-card:hover .card-link svg{ transform:translateX(3px); }

  /* ============ FOOTER ============ */
  .site-footer{ background:var(--c-primary-darker); color:#CBD8E1; margin-top:20px; }
  .site-footer .footer-top{ height:4px; background:linear-gradient(90deg,var(--c-accent),var(--c-primary-light)); }
  .footer-grid{ display:grid; grid-template-columns:1.3fr 1fr 1fr; gap:40px; padding:52px 0 36px; }
  .footer-col h4{ color:#fff; font-size:14px; letter-spacing:.06em; text-transform:uppercase; margin-bottom:16px; font-family:var(--font-body); font-weight:700; }
  .footer-brand{ display:flex; gap:12px; align-items:flex-start; margin-bottom:14px; }
  .footer-brand svg{ width:38px; height:38px; flex-shrink:0; }
  .footer-brand strong{ display:block; color:#fff; font-family:var(--font-display); font-size:16px; line-height:1.3; }
  .footer-col p{ font-size:13px; line-height:1.7; color:#A9BAC7; }
  .social-list{ display:flex; flex-direction:column; gap:12px; }
  .social-list a{ display:flex; align-items:center; gap:11px; font-size:13.5px; color:#CBD8E1; transition:color .15s ease; }
  .social-list a:hover{ color:var(--c-accent); }
  .social-list .icon-circle{ width:32px; height:32px; border-radius:50%; background:rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .social-list .icon-circle svg{ width:16px; height:16px; }
  .contact-list li{ display:flex; gap:11px; font-size:13.5px; margin-bottom:14px; color:#CBD8E1; align-items:flex-start; }
  .contact-list svg{ width:17px; height:17px; flex-shrink:0; margin-top:1px; color:var(--c-accent); }
  .footer-bottom{ border-top:1px solid rgba(255,255,255,.1); padding:18px 0; font-size:12px; color:#8CA0AF; text-align:center; }

  /* ============ TABS (year) ============ */
  .year-tabs{ display:inline-flex; background:var(--c-primary-tint); padding:5px; border-radius:999px; gap:4px; margin-bottom:30px; }
  .year-tabs button{
    background:none; border:none; padding:9px 22px; border-radius:999px; font-weight:700; font-size:13.5px;
    color:var(--c-primary); font-family:inherit; transition:background .15s ease, color .15s ease;
  }
  .year-tabs button.active{ background:var(--c-primary); color:#fff; }
  .year-panel{ display:none; }
  .year-panel.active{ display:block; animation:fadeIn .3s ease; }

  /* ============ PROPEMPERDA doc cards ============ */
  .doc-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
  .doc-card{
    display:flex; align-items:center; gap:14px; background:var(--c-surface);
    border:1px solid var(--c-border); border-radius:var(--radius-sm); padding:16px 18px;
    box-shadow:var(--shadow-sm); transition:border-color .15s ease, box-shadow .15s ease, transform .15s ease;
  }
  .doc-card:hover{ border-color:var(--c-accent); box-shadow:var(--shadow-md); transform:translateY(-2px); }
  .doc-card .doc-icon{ width:42px; height:42px; border-radius:10px; background:var(--c-accent-tint); color:var(--c-accent-dark); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .doc-card .doc-icon svg{ width:21px; height:21px; }
  .doc-card .doc-info{ flex-grow:1; min-width:0; }
  .doc-card .doc-info strong{ display:block; font-size:14px; font-weight:700; line-height:1.35; }
  .doc-card .doc-info span{ font-size:12px; color:var(--c-text-muted); }
  .doc-card .doc-open{ width:34px; height:34px; border-radius:50%; background:var(--c-primary-tint); color:var(--c-primary); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:background .15s ease, color .15s ease; }
  .doc-card .doc-open svg{ width:15px; height:15px; }
  .doc-card:hover .doc-open{ background:var(--c-primary); color:#fff; }

  /* ============ INFORMASI page - ranperda rows ============ */
  .sample-note{
    display:flex; gap:10px; align-items:flex-start; background:var(--c-warning-tint); border:1px solid #EAD7AE;
    color:#7A5313; padding:13px 16px; border-radius:var(--radius-sm); font-size:13px; margin-bottom:28px;
  }
  .sample-note svg{ width:17px; height:17px; flex-shrink:0; margin-top:1px; }

  .ranperda-list{ display:flex; flex-direction:column; gap:14px; }
  .ranperda-row{
    background:var(--c-surface); border:1px solid var(--c-border); border-radius:var(--radius-md);
    padding:20px 24px; box-shadow:var(--shadow-sm);
  }
  .ranperda-row__head{ display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:18px; flex-wrap:wrap; }
  .ranperda-row__head h4{ font-size:16px; font-weight:700; font-family:var(--font-body); }
  .ranperda-row__head .meta{ font-size:12.5px; color:var(--c-text-muted); margin-top:4px; }
  .badge{ font-size:11.5px; font-weight:700; padding:5px 12px; border-radius:999px; white-space:nowrap; letter-spacing:.02em; }
  .badge-selesai{ background:var(--c-success-tint); color:var(--c-success); }
  .badge-proses{ background:var(--c-warning-tint); color:var(--c-warning); }
  .badge-baru{ background:var(--c-info-tint); color:var(--c-info); }

  .stage-tracker-h{ display:flex; align-items:center; }
  .stage-tracker-h .stage-h{ display:flex; flex-direction:column; align-items:center; gap:8px; flex:1; position:relative; }
  .stage-tracker-h .stage-h .line{ position:absolute; top:12px; left:50%; width:100%; height:2px; background:var(--c-border); z-index:0; }
  .stage-tracker-h .stage-h:last-child .line{ display:none; }
  .stage-tracker-h .stage-h.done .line{ background:var(--c-accent); }
  .stage-tracker-h .node{ width:25px; height:25px; border-radius:50%; border:2.5px solid var(--c-border); background:#fff; z-index:1; display:flex; align-items:center; justify-content:center; }
  .stage-tracker-h .stage-h.done .node{ background:var(--c-accent); border-color:var(--c-accent); }
  .stage-tracker-h .stage-h.done .node svg{ width:12px; height:12px; color:#fff; }
  .stage-tracker-h .stage-h.current .node{ border-color:var(--c-primary); }
  .stage-tracker-h .stage-h.current .node::after{ content:""; width:8px; height:8px; border-radius:50%; background:var(--c-primary); }
  .stage-tracker-h .stage-h span{ font-size:11.5px; font-weight:600; color:var(--c-text-muted); text-align:center; }
  .stage-tracker-h .stage-h.current span{ color:var(--c-primary); font-weight:700; }
  .stage-tracker-h .stage-h.done span{ color:var(--c-text); }

  /* ============ SURVEY ============ */
  .legend-box{
    background:var(--c-primary-tint); border-radius:var(--radius-md); padding:20px 24px; margin-bottom:38px;
    display:flex; flex-wrap:wrap; gap:22px; align-items:center;
  }
  .legend-box .legend-title{ font-weight:700; font-size:13.5px; color:var(--c-primary); flex-basis:100%; margin-bottom:2px; }
  .legend-item{ display:flex; align-items:center; gap:8px; font-size:13px; color:var(--c-text); }
  .legend-item .num{ width:22px; height:22px; border-radius:50%; background:var(--c-primary); color:#fff; font-size:11.5px; font-weight:700; display:flex; align-items:center; justify-content:center; }

  .survey-section{ margin-bottom:40px; }
  .survey-section__title{ display:flex; align-items:baseline; gap:10px; margin-bottom:18px; padding-bottom:10px; border-bottom:2px solid var(--c-border); }
  .survey-section__title .letter{ font-family:var(--font-display); font-size:22px; color:var(--c-accent-dark); font-weight:700; }
  .survey-section__title h3{ font-size:17px; }

  .likert-row{
    display:flex; align-items:center; justify-content:space-between; gap:18px;
    padding:16px 4px; border-bottom:1px solid var(--c-border); flex-wrap:wrap;
  }
  .likert-row:last-child{ border-bottom:none; }
  .likert-q{ font-size:14.5px; flex:1 1 320px; }
  .likert-q .qnum{ color:var(--c-primary); font-weight:700; margin-right:6px; }
  .likert-scale{ display:flex; gap:7px; }
  .likert-opt{ position:relative; }
  .likert-opt input{ position:absolute; opacity:0; width:100%; height:100%; margin:0; cursor:pointer; }
  .likert-opt label{
    width:38px; height:38px; border-radius:50%; border:1.5px solid var(--c-border); background:#fff;
    display:flex; align-items:center; justify-content:center; font-size:13.5px; font-weight:700; color:var(--c-text-muted);
    transition:all .15s ease; cursor:pointer;
  }
  .likert-opt input:hover + label{ border-color:var(--c-primary-light); }
  .likert-opt input:checked + label{ background:var(--c-primary); border-color:var(--c-primary); color:#fff; transform:scale(1.06); }
  .likert-opt input:focus-visible + label{ outline:2.5px solid var(--c-accent); outline-offset:2px; }

  .open-q{ margin-bottom:22px; }
  .open-q label{ display:block; font-size:14.5px; font-weight:600; margin-bottom:8px; }
  .open-q label .qnum{ color:var(--c-primary); font-weight:700; margin-right:6px; }
  .open-q textarea{
    width:100%; border:1.5px solid var(--c-border); border-radius:var(--radius-sm); padding:13px 15px;
    font-family:inherit; font-size:14px; resize:vertical; min-height:80px; color:var(--c-text);
    transition:border-color .15s ease;
  }
  .open-q textarea:focus{ border-color:var(--c-primary); outline:none; }

  .survey-submit{ text-align:center; padding:30px 0 10px; }
  .survey-submit p{ font-size:12.5px; color:var(--c-text-muted); margin-top:12px; }
  .thankyou{
    display:none; text-align:center; background:var(--c-success-tint); border:1px solid #bfe0cf;
    border-radius:var(--radius-md); padding:38px 28px; margin-top:20px;
  }
  .thankyou.show{ display:block; animation:fadeIn .4s ease; }
  .thankyou svg{ width:44px; height:44px; color:var(--c-success); margin:0 auto 12px; }
  .thankyou h3{ font-size:19px; margin-bottom:8px; }
  .thankyou p{ color:var(--c-text-muted); font-size:14px; }

  footer + .toast { margin-bottom:20px; }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 900px){
    .main-nav{ position:fixed; top:var(--header-h); left:0; right:0; background:var(--c-primary-dark);
